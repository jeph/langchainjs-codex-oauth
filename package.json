{
  "name": "langchainjs-codex-oauth",
  "version": "0.1.6",
  "description": "Use ChatGPT Codex via OAuth as a LangChainJS chat model",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeph/langchainjs-codex-oauth.git"
  },
  "homepage": "https://github.com/jeph/langchainjs-codex-oauth#readme",
  "bugs": {
    "url": "https://github.com/jeph/langchainjs-codex-oauth/issues"
  },
  "keywords": [
    "langchain",
    "langchainjs",
    "langgraph",
    "codex",
    "oauth",
    "chatgpt"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "langchainjs-codex-oauth": "./bin/langchainjs-codex-oauth.js"
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run lint && pnpm run typecheck && pnpm run typecheck:build && pnpm run build:dist && pnpm run test:exports",
    "build:dist": "tsup",
    "build:release": "pnpm run clean && pnpm run lint && pnpm run typecheck && pnpm run typecheck:build && pnpm run test && pnpm run test:int && pnpm run test:int:extended && pnpm run build:dist && pnpm run test:exports",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { force: true, recursive: true }))\"",
    "prepublishOnly": "pnpm run build:release",
    "typecheck": "tsc --noEmit",
    "typecheck:build": "tsc --project tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:int": "vitest run --mode int",
    "test:int:extended": "vitest run --mode int-extended",
    "test:e2e": "pnpm run build:dist && vitest run --mode e2e",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\" \"tst/**/*.ts\" \"examples/**/*.ts\" \"*.{json,md,ts,mjs}\" \"bin/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tst/**/*.ts\" \"examples/**/*.ts\" \"*.{json,md,ts,mjs}\" \"bin/*.js\"",
    "auth:login": "pnpm build && node ./bin/langchainjs-codex-oauth.js auth login",
    "auth:login:manual": "pnpm build && node ./bin/langchainjs-codex-oauth.js auth login --manual",
    "auth:status": "pnpm build && node ./bin/langchainjs-codex-oauth.js auth status",
    "auth:logout": "pnpm build && node ./bin/langchainjs-codex-oauth.js auth logout",
    "example:hello": "tsx examples/langchain/hello.ts",
    "example:tools": "tsx examples/langchain/tools.ts",
    "example:agent": "tsx examples/langgraph/agent.ts",
    "smoke:live": "tsx examples/langchain/hello.ts",
    "verify:background-auth-refresh": "tsx scripts/verify-background-auth-refresh.ts",
    "test:exports": "node test_exports.mjs"
  },
  "dependencies": {
    "zod": "^4.4.1"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.31"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@langchain/core": "^1.1.42",
    "@langchain/langgraph": "^1.2.9",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "langchain": "^1.3.5",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "8.0.10"
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./auth": {
      "import": {
        "types": "./dist/auth/index.d.ts",
        "default": "./dist/auth/index.mjs"
      },
      "require": {
        "types": "./dist/auth/index.d.cts",
        "default": "./dist/auth/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.mjs"
      },
      "require": {
        "types": "./dist/client/index.d.cts",
        "default": "./dist/client/index.cjs"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/errors.d.ts",
        "default": "./dist/errors.mjs"
      },
      "require": {
        "types": "./dist/errors.d.cts",
        "default": "./dist/errors.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts"
}
