{
  "name": "langchainjs-codex-oauth",
  "version": "0.1.0",
  "description": "Use ChatGPT Codex via OAuth as a LangChainJS chat model",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "langchainjs-codex-oauth": "./bin/langchainjs-codex-oauth.js"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { force: true, recursive: true }))\"",
    "prebuild": "pnpm run clean && pnpm run lint && pnpm run typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:int": "vitest run --mode int",
    "test:int:extended": "vitest run --mode int-extended",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\" \"tst/**/*.ts\" \"examples/**/*.ts\" \"*.{json,md,ts,mjs}\" \"bin/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tst/**/*.ts\" \"examples/**/*.ts\" \"*.{json,md,ts,mjs}\" \"bin/*.js\"",
    "auth:login": "pnpm build && node ./bin/langchainjs-codex-oauth.js auth login",
    "auth:login:manual": "pnpm build && node ./bin/langchainjs-codex-oauth.js auth login --manual",
    "auth:status": "pnpm build && node ./bin/langchainjs-codex-oauth.js auth status",
    "auth:logout": "pnpm build && node ./bin/langchainjs-codex-oauth.js auth logout",
    "example:hello": "tsx examples/langchain/hello.ts",
    "example:tools": "tsx examples/langchain/tools.ts",
    "example:agent": "tsx examples/langgraph/agent.ts",
    "smoke:live": "tsx examples/langchain/hello.ts"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.31"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.3.0",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "langchain": "^1.2.30",
    "prettier": "^3.5.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts"
}
